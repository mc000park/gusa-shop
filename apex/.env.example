# =====================================================
# GUSA apex 서버 필수 환경변수
# 이 파일을 복사해 .env 로 만든 뒤 실제 값을 채우세요.
# .env 는 .gitignore에 포함돼 있어 커밋되지 않습니다.
# =====================================================

# Spring 프로파일 (dev | prod)
SPRING_PROFILES_ACTIVE=prod

# JWT 서명 키 — 운영 시 32자 이상 랜덤 문자열 필수
# 생성 예시: openssl rand -hex 32
JWT_SECRET=

# CORS 허용 출처 (쉼표 구분)
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ── PG 결제 키 ──────────────────────────────────────
# Toss Payments
PG_TOSS_SECRET_KEY=

# KakaoPay
PG_KAKAO_ADMIN_KEY=

# PortOne V2
PG_PORTONE_SECRET=

# ── 운영 DB ─────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/gusa
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=
